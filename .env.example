# Server
PORT=8080

# MySQL database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=tripla_technical_test

# Mock accounting behavior
# Options:
# - force_success: every accounting sync succeeds
# - force_fail: every accounting sync fails like HTTP 500
# - random or empty: 90% success, 5% known error, 5% internal server error
ACCOUNTING_MOCK_MODE=random
